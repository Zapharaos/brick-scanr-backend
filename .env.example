# BrickScanr Backend Environment Configuration
# Copy this file to .env and update with your settings

# Environment (leave empty for dev, set to "prod" for production)
APP_ENV=

# Backend port
BACKEND_PORT=3000

# Redis port
REDIS_PORT=6379

# Redis password - CHANGE THIS IN PRODUCTION!
BRICK_SCANR_REDIS_PASSWORD=changeme123!

# Docker Compose file selection
# Development (default): docker-compose.dev.yml
# Production: docker-compose.prod.yml
COMPOSE_FILE=docker-compose.dev.yml

# Add any other configuration overrides here using BRICK_SCANR_ prefix
# Example:
# BRICK_SCANR_LOGGER_LEVEL=debug
